# =============================================================================
# AgentFinance v3 — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your credentials:
#   cp .env.example .env
#
# GET CTRADER CREDENTIALS:
#   1. Visit: https://www.ctrader.com/apps/
#   2. Create a new app to get CLIENT_ID and CLIENT_SECRET
#   3. Generate an ACCESS_TOKEN from your cTrader platform
#   4. Your ACCOUNT_ID is your Pepperstone demo account number
#
# Pepperstone Demo Account: #46729678
# =============================================================================

# ============================================================================
# CTRADER LIVE TRADING
# ============================================================================
# Option A: Direct TCP (uses ctrader-open-api package directly)
#   Set CTRADER_CLIENT_ID, CTRADER_CLIENT_SECRET, CTRADER_ACCESS_TOKEN
#   The code connects directly to demo/live.ctraderapi.com:5035
CTRADER_CLIENT_ID=your_ctrader_client_id_here
CTRADER_CLIENT_SECRET=your_ctrader_client_secret_here
CTRADER_ACCESS_TOKEN=your_ctrader_access_token_here
CTRADER_ACCOUNT_ID=46729678
CTRADER_HOST=demo           # "demo" (default) or "live"

# Option B: Docker REST API (recommended for isolated deployment)
#   Set CTRADER_REST_URL to point to the Docker container
#   Start the container with: cd ctrader/ && docker compose up --build -d
#   The REST client connects via HTTP instead of raw TCP/Protobuf
CTRADER_REST_URL=http://localhost:9009

# REST API Key for Docker cTrader server (optional but recommended):
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Required in X-API-Key header for all write operations (/orders/*, /trendbars POST)
REST_API_KEY=

# ============================================================================
# MARKET DATA PROVIDERS
# ============================================================================
POLYGON_API_KEY=your_polygon_api_key
OANDA_API_KEY=your_oanda_api_key
OANDA_ACCOUNT_ID=your_oanda_account_id
FRED_API_KEY=your_fred_api_key          # Free at: https://fred.stlouisfed.org/docs/api/api_key.html
NEWSAPI_KEY=your_newsapi_key             # Free at: https://newsapi.org

# ============================================================================
# TRADING PARAMETERS
# ============================================================================
MAX_RISK_PER_TRADE=0.01      # 1% of account per trade
MAX_DAILY_DRAWDOWN=0.03      # 3% daily loss = halt
MAX_WEEKLY_DRAWDOWN=0.05     # 5% weekly loss = pause
MAX_MONTHLY_DRAWDOWN=0.08    # 8% monthly loss = kill switch
INITIAL_BALANCE=10000        # Starting demo balance

# ============================================================================
# NOTIFICATIONS
# ============================================================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
