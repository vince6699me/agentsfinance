# cTrader REST API Server — Environment Template
# Copy to ../.env and fill in your credentials
# =============================================

# cTrader OpenAPI Credentials (from https://connect.spotware.com/apps)
CTRADER_CLIENT_ID=your_client_id_here
CTRADER_CLIENT_SECRET=your_client_secret_here

# Access Token (from cTrader platform or Spotware Developer Portal)
# For demo: use your Pepperstone demo account token
# For live: use your Pepperstone live account token
CTRADER_ACCESS_TOKEN=your_access_token_here

# Trading Account
CTRADER_ACCOUNT_ID=46729678
CTRADER_HOST=demo

# REST API Server (inside Docker container)
# This is the URL the REST client uses to connect to the Docker container
CTRADER_REST_URL=http://localhost:9009

# ─────────────────────────────────────────────
# REST API Authentication (CRITICAL for live trading)
# ─────────────────────────────────────────────
# Generate a secure random key: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# All write endpoints (/orders/*, /trendbars POST) require X-API-Key header.
# Read-only endpoints (/health, /status, /symbols, /positions, /orders, /account) are open.
# Leave blank to disable authentication (ONLY for local development).
REST_API_KEY=change_me_to_a_secure_random_key
