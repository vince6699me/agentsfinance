# AgentFinance v3 - Environment Configuration Template
# Copy to .env and fill in your API keys

# ============================================
# Trading Execution (cTrader / Pepperstone)
# ============================================
CTRADER_ACCESS_TOKEN=your_ctrader_demo_access_token
CTRADER_ACCOUNT_ID=5249494
CTRADER_SERVER=demo.ctraderapi.com
TRADING_MODE=demo

# ============================================
# Market Data APIs
# ============================================
# OANDA - Forex data
OANDA_API_KEY=your_oanda_api_key
OANDA_ACCOUNT_ID=your_oanda_account_id
OANDA_STREAMING_URL=https://stream-fxpractice.oanda.com

# Polygon.io - Stocks, Indices, Crypto
POLYGON_API_KEY=your_polygon_api_key

# FRED - Economic data (free)
FRED_API_KEY=your_fred_api_key

# NewsAPI - Financial news
NEWS_API_KEY=your_newsapi_key

# TradingEconomics - Global economic data
TRADING_ECONOMICS_KEY=your_te_key

# ============================================
# Database & Storage
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# Redis (for signal caching)
REDIS_URL=redis://localhost:6379

# ============================================
# Communication
# ============================================
# Telegram Bot for alerts
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Notion (for journal entries)
NOTION_TOKEN=your_notion_integration_token
NOTION_WEEKLY_DB_ID=your_weekly_reports_database_id

# ============================================
# n8n Workflow Automation
# ============================================
N8N_WEBHOOK_URL=http://localhost:5678/webhook

# ============================================
# Paperclip Orchestration
# ============================================
PAPERCLIP_API_URL=http://localhost:4000
PAPERCLIP_API_KEY=your_paperclip_api_key

# ============================================
# Apex Platform (optional)
# ============================================
APEX_API_KEY=your_apex_key

# ============================================
# Kill Zone Defaults (EST)
# ============================================
ASIAN_START=21:00
ASIAN_END=04:00
LONDON_OPEN_START=02:50
LONDON_OPEN_END=04:00
LONDON_START=03:00
LONDON_END=12:00
NY_OPEN_START=08:00
NY_OPEN_END=12:00
LONDON_CLOSE_START=10:30
LONDON_CLOSE_END=11:00
NY_CLOSE_START=16:00
NY_CLOSE_END=17:00

# ============================================
# Risk Management Defaults
# ============================================
MAX_RISK_PER_TRADE=0.01
MAX_DAILY_DRAWDOWN=0.03
MAX_POSITIONS=5
MIN_RR_RATIO=1.5
MIN_CONFIDENCE=0.75
MAX_CORRELATION_OVERLAP=0.8
PRE_NEWS_BLOCK_MIN=15
POST_NEWS_BLOCK_MIN=15
MAX_SPREAD_MULTIPLIER=3.0
SIGNAL_MAX_AGE_HOURS=4
MAX_MONTHLY_DRAWDOWN=0.08

# ============================================
# Backtesting
# ============================================
BACKTEST_INITIAL_BALANCE=10000
BACKTEST_COMMISSION_FX=0.00007
BACKTEST_SLIPPAGE_FX=0.00002
WALK_FORWARD_IN_SAMPLE_MONTHS=6
WALK_FORWARD_OUT_SAMPLE_MONTHS=2
MONTE_CARLO_RUNS=1000
